{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": "!newData.exists() && auth !== null",
        "settings": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "phase": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "dealer": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "currentTurn": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "turnDeadline": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "players": {
          "$playerId": {
            ".write": "auth !== null && ($playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid)"
          }
        },
        "hostId": {
          ".write": "!data.parent().exists() || data.parent().child('hostId').val() === auth.uid"
        },
        "kickVotesEnabled": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "music": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "cardsRemaining": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "runningCount": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "showCount": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "roundCount": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "shoeRoundCount": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "createdAt": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "chat": {
          "$msgId": {
            ".write": "auth !== null"
          }
        },
        "emojiEvents": {
          "$eventId": {
            ".write": "auth !== null"
          }
        },
        "pendingTips": {
          "$tipId": {
            ".write": "auth !== null"
          }
        },
        "rainEvents": {
          "$eventId": {
            ".write": "auth !== null"
          }
        },
        "kekryEvents": {
          "$eventId": {
            ".write": "auth !== null"
          }
        },
        "gameType": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "rouletteBets": {
          "$uid": {
            ".write": "auth !== null && ($uid === auth.uid || data.parent().parent().child('hostId').val() === auth.uid)"
          }
        },
        "lastSpin": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "handNumber": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "communityCards": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "pot": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "sidePots": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "currentBet": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "minRaise": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "dealerSeat": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "actionSeat": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        },
        "lastAggressor": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.parent().exists()"
        }
      }
    },
    "privateData": {
      "$roomCode": {
        "holeCards": {
          "$uid": {
            ".read": "auth !== null && $uid === auth.uid",
            ".write": "auth !== null && root.child('rooms').child($roomCode).child('hostId').val() === auth.uid"
          }
        }
      }
    },
    "publicRooms": {
      ".read": "auth !== null",
      "$roomCode": {
        ".write": "auth !== null && root.child('rooms').child($roomCode).child('hostId').val() === auth.uid"
      }
    }
  }
}
